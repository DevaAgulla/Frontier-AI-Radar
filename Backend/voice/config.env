# =============================================================================
# ElevenLabs Voice Digest — Configuration
# =============================================================================
# 1. Paste your ElevenLabs API key below (get it from elevenlabs.io/app/settings)
# 2. Choose a voice preset: "rachel" (professional female) or "adam" (deep male)
# 3. Run: python voice/generate_voice_digest.py
# =============================================================================

ELEVENLABS_API_KEY=sk_3f1c42bd96a182425b1a768efbc91e17b682ac025660e819

# Voice preset to use by default: "rachel" or "adam"
# rachel = calm, professional female narrator (good for executive digests)
# adam   = deep, authoritative male narrator
VOICE_PRESET=rachel

# Output audio format: mp3_44100_128 (default) or mp3_22050_32 (smaller file)
AUDIO_FORMAT=mp3_44100_128

# Max characters sent per TTS chunk (ElevenLabs free tier: 5000, paid: 10000)
# Reduce if you hit "quota exceeded" errors
CHUNK_SIZE=4500
